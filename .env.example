# Supabase — shared SundayChess project, dedicated `quiz` schema
# (provisioned via scripts/provision-shared.mjs).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public base URL used to build the join URL + QR code on the board.
NEXT_PUBLIC_BASE_URL=https://quiz.sundaysuite.app

# ---------------------------------------------------------------------------
# Sunday Account — HOST sign-in (SSO). Players/joiners stay 100% code-based;
# this is ONLY for the vert/host dashboard ("Spillene mine").
#
# The auth client points at the shared Sunday Account ISSUER project (same
# project SundayInfo's NEXT_PUBLIC_SUPABASE_URL / ANON_KEY point at) — this is
# SEPARATE from the app's own DATA project above (NEXT_PUBLIC_SUPABASE_URL).
NEXT_PUBLIC_SUNDAY_AUTH_URL=https://YOUR-ISSUER-PROJECT.supabase.co
NEXT_PUBLIC_SUNDAY_AUTH_ANON_KEY=eyJ...

# Share the sb-* session cookie across *.sundaysuite.app (PRODUCTION ONLY —
# leave UNSET in local dev so cookies work on localhost).
NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app

# Allow-list of host emails (comma/space separated). Only these Sunday accounts
# may open the host dashboard + delete games. Empty/unset = nobody is a host.
QUIZ_ADMIN_EMAILS=you@example.com,co-host@example.com

# Anthropic API key for the AI statement-set generator ("Lag med AI"). SERVER
# ONLY — set it as a Worker secret in production:
#   npx wrangler secret put ANTHROPIC_API_KEY
# Optional: with no key the AI option is disabled and manual set creation is
# unaffected.
ANTHROPIC_API_KEY=sk-ant-...
