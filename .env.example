# Supabase — shared SundayChess project, dedicated `quiz` schema
# (provisioned via scripts/provision-shared.mjs).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public base URL used to build the join URL + QR code on the board.
NEXT_PUBLIC_BASE_URL=https://quiz.sundaysuite.app

# Anthropic API key for the AI statement-set generator ("Lag med AI"). SERVER
# ONLY — set it as a Worker secret in production:
#   npx wrangler secret put ANTHROPIC_API_KEY
# Optional: with no key the AI option is disabled and manual set creation is
# unaffected.
ANTHROPIC_API_KEY=sk-ant-...
